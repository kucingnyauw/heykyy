{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@heykyy/components/*": ["packages/components/src/*"],
      "@heykyy/constant/*": ["packages/constant/src/*"],
      "@heykyy/theme/*": ["packages/styles/src/*"],
      "@heykyy/utils/*": ["packages/utils/src/*"],
      "@heykyy/config/*": ["packages/config/src/*"]
    },
    "module": "ESNext",
    "moduleResolution": "Node",
    "target": "ESNext",
    "jsx": "react-jsx",
    "types": []
  },
  "include": [
    "packages/**/*",
    "apps/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "logs"
  ]
}