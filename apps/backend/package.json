{
    "name": "@heykyy/backend",
    "version": "1.0.0",
    "type": "module",
    "main": "src/main.js",
    "description": "Backend server for personal portfolio website, handling APIs, database, and integrations with third-party services.",
    "author": "Rifky Firmansyah",
    "license": "ISC",
    "scripts": {
        "dev": "nodemon src/main.js",
        "build": "babel src --out-dir dist --extensions \".js\" --copy-files",
        "start": "node dist/main.js",
        "test": "jest -i",
        "seed": "node src/seed.js",
        "db:generate": "prisma generate",
        "db:push": "prisma db push",
        "db:pull": "prisma db pull",
        "db:reset": "prisma migrate reset",
        "db:studio": "prisma studio",
        "vercel-build": "npm run db:generate && npm run build"
    },
    "jest": {
        "transform": {
            "^.+\\.[tj]sx?$": "babel-jest"
        }
    },
    "dependencies": {
        "@babel/cli": "^7.24.7",
        "@babel/core": "^7.24.7",
        "@babel/node": "^7.24.7",
        "@babel/plugin-transform-runtime": "^7.29.0",
        "@babel/preset-env": "^7.24.7",
        "@babel/runtime": "^7.29.2",
        "@deepgram/sdk": "^4.11.3",
        "@prisma/client": "^5.22.0",
        "@sentry/node": "^10.46.0",
        "@supabase/supabase-js": "^2.89.0",
        "@upstash/redis": "^1.36.0",
        "@heykyy/constant": "*",
        "axios": "^1.11.0",
        "cookie-parser": "^1.4.7",
        "cookie-session": "^2.1.1",
        "cors": "^2.8.5",
        "date-fns": "^3.6.0",
        "dotenv": "^16.4.5",
        "ejs": "^4.0.1",
        "express": "^4.19.2",
        "express-rate-limit": "^8.0.0",
        "helmet": "^8.1.0",
        "html-to-text": "^9.0.5",
        "joi": "^17.13.3",
        "morgan": "^1.10.1",
        "multer": "^2.0.2",
        "sharp": "^0.34.5",
        "winston": "^3.17.0",
